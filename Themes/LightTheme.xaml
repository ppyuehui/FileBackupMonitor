<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ 浅色主题颜色 ═══ -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F7"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="AccentHover" Color="#6D28D9"/>
    <SolidColorBrush x:Key="AccentPress" Color="#5B21B6"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#111111"/>
    <SolidColorBrush x:Key="MutedText" Color="#333333"/>
    <SolidColorBrush x:Key="SubtleText" Color="#555555"/>
    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorder" Color="#CBD5E1"/>

    <!-- 顶栏按钮在浅色下用深色文字 -->
    <SolidColorBrush x:Key="AccentButtonText" Color="#1E293B"/>
    <SolidColorBrush x:Key="AccentButtonBorder" Color="#CBD5E180"/>

    <!-- 悬停/按下叠加色（浅色模式用深色叠加） -->
    <SolidColorBrush x:Key="HoverOverlay" Color="#10000000"/>
    <SolidColorBrush x:Key="PressOverlay" Color="#20000000"/>
    <SolidColorBrush x:Key="HoverOverlayLight" Color="#08000000"/>
    <SolidColorBrush x:Key="HoverOverlayStrong" Color="#18000000"/>

</ResourceDictionary>
