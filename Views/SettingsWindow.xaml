<Window x:Class="FileBackupMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FileBackupMonitor.ViewModels"
        Title="设置" Height="840" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙️ 监控设置" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">

                <!-- ═══ 文件夹对列表 ═══ -->
                <TextBlock Text="监控 → 备份 文件夹对" Foreground="{DynamicResource PrimaryText}"
                           FontWeight="Medium" Margin="0,0,0,2"/>
                <TextBlock Text="每一对独立运作：左侧文件夹的变更会备份到右侧文件夹"
                           Foreground="{DynamicResource SubtleText}" FontSize="11" Margin="0,0,0,6"/>

                <Border Background="{DynamicResource InputBackground}" CornerRadius="6"
                        BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                        Padding="2" Margin="0,0,0,6">
                    <ListBox ItemsSource="{Binding FolderPairs}"
                             SelectedItem="{Binding SelectedPair}"
                             MinHeight="100" MaxHeight="160"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding WatchFolder}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PrimaryText}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="  →  " Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding BackupFolder}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource MutedText}" FontSize="12"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="➕ 添加一对" Command="{Binding AddPairCommand}"
                            Style="{DynamicResource SecondaryButton}" Padding="14,6" Margin="0,0,8,0"/>
                    <Button Content="➖ 删除选中" Command="{Binding RemovePairCommand}"
                            Style="{DynamicResource GhostButton}" Padding="14,6" Margin="0,0,8,0"/>
                    <!--<Button Content="⬆️ 清空全部" Command="{Binding ClearAllPairsCommand}"
                            Style="{DynamicResource GhostButton}" Padding="14,6"/>-->
                </StackPanel>

                <!-- ═══ 批量添加 ═══ --><!--
                <TextBlock Text="批量添加文件夹对" Foreground="{DynamicResource PrimaryText}"
                           FontWeight="Medium" Margin="0,8,0,2"/>
                <TextBlock Text="每行一对，用 | 分隔监控文件夹和备份文件夹，例如："
                           Foreground="{DynamicResource SubtleText}" FontSize="11" Margin="0,0,0,2"/>
                <TextBlock Text="C:\源文件夹1 | D:\备份文件夹1" Foreground="{DynamicResource AccentBrush}"
                           FontSize="11" FontFamily="Consolas" Margin="0,0,0,4"/>
                <TextBox Text="{Binding BatchInputText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource DarkTextBox}" TextWrapping="Wrap"
                         AcceptsReturn="True" MinHeight="60" MaxHeight="120"
                         FontFamily="Consolas" FontSize="11"
                         Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="📥 导入" Command="{Binding BatchImportCommand}"
                            Style="{DynamicResource SecondaryButton}" Padding="14,6" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding BatchImportStatus}" Foreground="{DynamicResource SuccessBrush}"
                               VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>-->

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                <!-- 延迟备份 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="延迟备份时间" Foreground="{DynamicResource PrimaryText}" FontWeight="Medium"/>
                        <TextBlock Text="文件修改后等待多久再备份（秒）"
                                   Foreground="{DynamicResource SubtleText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" Text="{Binding Settings.DelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource DarkTextBox}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- 保留天数 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="旧备份保留天数" Foreground="{DynamicResource PrimaryText}" FontWeight="Medium"/>
                        <TextBlock Text="超过此天数自动删除，0 = 永不删除"
                                   Foreground="{DynamicResource SubtleText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" Text="{Binding Settings.RetentionDays, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource DarkTextBox}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- 最大日志数 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="最大备份日志数量" Foreground="{DynamicResource PrimaryText}" FontWeight="Medium"/>
                        <TextBlock Text="日志文件中保存的备份记录数量"
                                   Foreground="{DynamicResource SubtleText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" Text="{Binding Settings.MaxBackupLogs, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource DarkTextBox}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- 最近日志条数 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="加载最近日志条数" Foreground="{DynamicResource PrimaryText}" FontWeight="Medium"/>
                        <TextBlock Text="从磁盘加载到内存用于显示的日志条数"
                                   Foreground="{DynamicResource SubtleText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" Text="{Binding Settings.RecentLogCount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource DarkTextBox}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>

                <!-- 忽略模式 -->
                <TextBlock Text="忽略的文件（扩展名或文件名，用逗号分隔）" Foreground="{DynamicResource PrimaryText}"
                           FontWeight="Medium" Margin="0,0,0,4"/>
                <TextBlock Text="示例：*.tmp, *.log, node_modules, thumbs.db"
                           Foreground="{DynamicResource SubtleText}" FontSize="11" Margin="0,0,0,6"/>
                <TextBox Text="{Binding IgnorePatternsText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource DarkTextBox}" TextWrapping="Wrap" Margin="0,0,0,16"/>


                <!-- 忽略文件夹（独立输入框） -->
                <TextBlock Text="忽略的文件夹路径（支持通配符，用逗号分隔）" Foreground="{DynamicResource PrimaryText}"
                           FontWeight="Medium" Margin="0,0,0,4"/>
                <TextBlock Text="示例：C:\Temp\*, node_modules\*, .git\*, cache\*"
                           Foreground="{DynamicResource SubtleText}" FontSize="11" Margin="0,0,0,6"/>
                <TextBox Text="{Binding IgnoredFoldersText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource DarkTextBox}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- ═══ 文件格式扫描 ═══ -->
                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="文件格式监控" Foreground="{DynamicResource PrimaryText}" FontWeight="Medium"/>
                        <TextBlock Text="排除模式：勾选的格式不备份；包含模式：只备份勾选的格式"
                                   Foreground="{DynamicResource SubtleText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🔍 扫描" Command="{Binding ScanExtensionsCommand}"
                            Style="{DynamicResource SecondaryButton}" Padding="14,6" VerticalAlignment="Center"/>
                </Grid>

                <!-- 模式切换 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="排除模式" IsChecked="{Binding IsExcludeMode, Mode=TwoWay}"
                                 Foreground="{DynamicResource PrimaryText}" Margin="0,0,16,0"
                                 GroupName="FilterMode" VerticalContentAlignment="Center"/>
                    <RadioButton Content="包含模式" IsChecked="{Binding IsIncludeMode, Mode=TwoWay}"
                                 Foreground="{DynamicResource PrimaryText}" Margin="0,0,16,0"
                                 GroupName="FilterMode" VerticalContentAlignment="Center"/>
                    <Button Content="恢复默认" Command="{Binding RestoreDefaultExcludeCommand}"
                            Style="{DynamicResource GhostButton}" Padding="10,4" FontSize="11"
                            Visibility="{Binding IsExcludeMode, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="清空" Command="{Binding ClearIncludeCommand}"
                            Style="{DynamicResource GhostButton}" Padding="10,4" FontSize="11"
                            Visibility="{Binding IsIncludeMode, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <TextBlock Text="{Binding ExtensionScanStatus}" Foreground="{DynamicResource SubtleText}"
                           FontSize="11" Margin="0,0,0,6"/>

                <!-- 分类快捷按钮（扫描后才显示） -->
                <StackPanel Visibility="{Binding HasScannedExtensions, Converter={StaticResource BoolToVisibility}}">
                    <WrapPanel Margin="0,0,0,8">
                    <Button Content="📄 文档" Command="{Binding ApplyCategoryCommand}" CommandParameter="文档"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=文档}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="文档"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="🖼 图片" Command="{Binding ApplyCategoryCommand}" CommandParameter="图片"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=图片}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="图片"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="💻 源码" Command="{Binding ApplyCategoryCommand}" CommandParameter="源码"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=源码}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="源码"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="📦 压缩包" Command="{Binding ApplyCategoryCommand}" CommandParameter="压缩包"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=压缩包}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="压缩包"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="⚙️ 可执行文件" Command="{Binding ApplyCategoryCommand}" CommandParameter="可执行文件"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=可执行文件}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="可执行文件"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="🎵 音视频" Command="{Binding ApplyCategoryCommand}" CommandParameter="音视频"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=音视频}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="音视频"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="🔧 工程软件" Command="{Binding ApplyCategoryCommand}" CommandParameter="工程软件"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=工程软件}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="工程软件"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="🗄 数据库" Command="{Binding ApplyCategoryCommand}" CommandParameter="数据库"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=数据库}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="数据库"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="🗑 临时文件" Command="{Binding ApplyCategoryCommand}" CommandParameter="临时文件"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=临时文件}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="临时文件"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="🔧 辉哥软件" Command="{Binding ApplyCategoryCommand}" CommandParameter="辉哥软件"
                            Style="{DynamicResource CategoryButton}"
                            Background="{Binding ActiveCategories, Converter={StaticResource CategoryToBrush}, ConverterParameter=辉哥软件}"
                            MouseRightButtonUp="CategoryButton_RightClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="编辑扩展名" Command="{Binding EditCategoryCommand}" CommandParameter="辉哥软件"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </WrapPanel>

                <Button Content="🔄 恢复所有分类拓展名" Command="{Binding ResetAllCategoriesCommand}"
                        Style="{DynamicResource CategoryButton}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>

                <Border Background="{DynamicResource InputBackground}" CornerRadius="6"
                        BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                        Padding="2" Margin="0,0,0,8" MaxHeight="240">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 标题行 -->
                        <Grid Grid.Row="0" Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding AllExtensionsChecked}"
                                      Command="{Binding ToggleAllExtensionsCommand}"
                                      ToolTip="全选/全不选" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="扩展名" Foreground="{DynamicResource MutedText}"
                                       FontWeight="Medium" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="文件数" Foreground="{DynamicResource MutedText}"
                                       FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Right"
                                       FontFamily="Consolas" Margin="0,0,8,0"/>
                        </Grid>
                        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                        <!-- 数据行 -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding Extensions}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,3" Height="26">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsMonitored, Mode=TwoWay}"
                                                  VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Extension}"
                                                   Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                   Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" FontFamily="Consolas"
                                                   Margin="0,0,8,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 排序按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="按勾选排序" Command="{Binding SortByCheckedCommand}"
                            Style="{DynamicResource GhostButton}" Padding="10,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button Content="按扩展名排序" Command="{Binding SortByExtensionCommand}"
                            Style="{DynamicResource GhostButton}" Padding="10,4" FontSize="11"/>
                </StackPanel>
                <!-- 底部说明 -->
                <Border Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="提示：" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Text="• IgnorePatterns 匹配文件名/扩展名（如 *.tmp, node_modules）&#x0a;• IgnoredFolders 匹配文件夹路径，会忽略该文件夹内所有文件（如 C:\Temp\*）&#x0a;• 两个列表都支持通配符 *（任意字符）和 ?（单字符）&#x0a;• 使用逗号分隔多个规则，前后空格会自动去除"
                                   Foreground="{DynamicResource SubtleText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>


                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                <CheckBox Content="监控子文件夹" IsChecked="{Binding Settings.IncludeSubfolders}"
                          Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8" Style="{DynamicResource DarkCheckBox}"/>
                <CheckBox Content="开机自启" IsChecked="{Binding Settings.StartWithWindows}"
                          Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8" Style="{DynamicResource DarkCheckBox}"/>
                <CheckBox Content="关闭时最小化到托盘" IsChecked="{Binding Settings.MinimizeToTray}"
                          Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8" Style="{DynamicResource DarkCheckBox}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{DynamicResource SecondaryButton}" Padding="20,8" Margin="0,0,8,0"/>
            <Button Content="💾 保存" Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{DynamicResource PrimaryButton}" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
