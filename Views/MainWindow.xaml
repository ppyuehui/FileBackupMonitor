<Window x:Class="FileBackupMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件备份监控助手" Height="620" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <!-- DataContext 由 MainWindow.xaml.cs 构造函数中设置，避免双重初始化 -->
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 顶栏 ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="16,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📁 文件备份监控" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{Binding ThemeToggleText}" Command="{Binding ThemeToggleCommand}"
                            Style="{DynamicResource AccentButton}" Margin="0,0,8,0" Padding="10,6"
                            FontSize="16" ToolTip="切换明/暗主题"/>
                    <Button Content="⚙️ 设置" Command="{Binding OpenSettingsCommand}"
                            Style="{DynamicResource AccentButton}" Margin="0,0,8,0" Padding="14,6"/>
                    <Button Content="📋 实时日志" Command="{Binding OpenLogWindowCommand}"
                            Style="{DynamicResource AccentButton}" Margin="0,0,8,0" Padding="14,6"
                            ToolTip="打开实时日志监控窗口"/>
                    <Button Content="{Binding StatusText}" Command="{Binding StartCommand}"
                            Style="{DynamicResource AccentButton}" Padding="14,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 路径信息条 ═══ -->
        <Border Grid.Row="1" Background="{DynamicResource CardBrush}" Padding="16,10" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource BorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 多对文件夹：用 ItemsControl 展示，每对一行 -->
                <ItemsControl Grid.Column="0" ItemsSource="{Binding FolderPairDisplayList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="{Binding WatchFolder}" Foreground="{DynamicResource PrimaryText}"
                                           FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                <TextBlock Text=" → " Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="11"/>
                                <TextBlock Text="{Binding BackupFolder}" Foreground="{DynamicResource MutedText}"
                                           FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">                  
                    <TextBlock Text="{Binding StatsText}" Foreground="{DynamicResource MutedText}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 备份日志列表 ═══ -->
        <Border Grid.Row="2" Margin="16,8" Background="{DynamicResource CardBrush}"
                CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Grid>
                <!-- 空状态 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding Logs.Count, Converter={StaticResource ZeroToVisible}}">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="还没有备份记录" FontSize="16" Foreground="{DynamicResource MutedText}"
                               Margin="0,12,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="点击「开始监控」后，修改监控文件夹中的文件即会自动备份"
                               Foreground="{DynamicResource SubtleText}" HorizontalAlignment="Center"/>
                </StackPanel>

                <ListView ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">                  
                    <ListView.ContextMenu>
                        <ContextMenu Style="{DynamicResource ModernContextMenuStyle}">
                            <MenuItem Header="打开备份文件" 
                                      Style="{DynamicResource ModernMenuItemStyle}"
                                      Icon="{DynamicResource IconOpenFile}"
                                      Command="{Binding OpenFileCommand}" 
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="打开原文件所在文件夹" 
                                      Style="{DynamicResource ModernMenuItemStyle}"
                                      Icon="{DynamicResource IconOpenFolder}"
                                      Command="{Binding OpenOriginalLocationCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="打开备份所在文件夹" 
                                      Style="{DynamicResource ModernMenuItemStyle}"
                                      Icon="{DynamicResource IconOpenFolder}"
                                      Command="{Binding OpenFileLocationCommand}" 
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource BorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Time, StringFormat=HH:mm:ss}"
                                               Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" FontSize="12"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource PrimaryText}"
                                                   FontWeight="Medium" FontSize="12"/>
                                        <Grid  Margin="0,1,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <DockPanel Grid.Column="0"  Margin="0,1,0,0">
                                                <TextBlock Text="📂 源：" Foreground="{DynamicResource AccentBrush}" FontSize="10"/>
                                                <TextBlock Text="{Binding SourceFullPath}" Foreground="{DynamicResource MutedText}"
                                                           FontSize="10" TextWrapping="Wrap"/>
                                            </DockPanel>
                                            <DockPanel Grid.Column="1"  Margin="0,1,0,0">
                                                <TextBlock Text="💾 目标：" Foreground="{DynamicResource SubtleText}" FontSize="10"/>
                                                <TextBlock Text="{Binding BackupPath}" Foreground="{DynamicResource MutedText}"
                                                           FontSize="10" TextWrapping="Wrap"/>
                                            </DockPanel>
                                        </Grid>                                       
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}"
                                               Foreground="{DynamicResource MutedText}" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Column="3" Text="{Binding Status}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource SuccessBrush}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ═══ 底栏 ═══ -->
        <Border Grid.Row="3" Background="{DynamicResource CardBrush}" Padding="16,8"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="▶ 开始监控" Command="{Binding StartCommand}"
                            Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0" Padding="16,6"/>
                    <Button Content="⏹ 停止" Command="{Binding StopCommand}"
                            Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0" Padding="16,6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button x:Name="btnCheckUpdate" Content="🔍 检查更新" Click="CheckUpdateButton_Click"
                            Style="{DynamicResource GhostButton}" Padding="12,6" Margin="0,0,8,0"/>
                    <Button x:Name="btnUpdate" Content="🔄 有新版本可用！点击更新" Click="UpdateButton_Click"
                            Visibility="Collapsed"
                            Style="{DynamicResource SecondaryButton}" Padding="12,6" Margin="0,0,12,0"/>
                    <Button Content="📂 错误日志" Command="{Binding OpenErrorLogFolderCommand}"
                            Style="{DynamicResource GhostButton}" Padding="12,6" Margin="0,0,12,0"/>
                    <Button Content="📂 文件日志" Command="{Binding OpenLogFolderCommand}"
                            Style="{DynamicResource GhostButton}" Padding="12,6" Margin="0,0,12,0"/>
                    <Button Content="{Binding RecentLoadText}" Command="{Binding LoadRecentLogsCommand}"
                            Style="{DynamicResource GhostButton}" Padding="12,6" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Button Content="🗑 清空日志" Command="{Binding ClearLogsCommand}"
                            Style="{DynamicResource GhostButton}" Padding="12,6"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
