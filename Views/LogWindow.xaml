<Window x:Class="FileBackupMonitor.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:FileBackupMonitor.Converters"      
        mc:Ignorable="d"
        Title="实时日志监控" Height="600" Width="800"       
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Topmost="False">   
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" 
                Padding="14,10" CornerRadius="6" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="📋 实时日志输出" 
                           FontWeight="Bold" FontSize="16"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}"
                           Margin="0,0,20,0"/>
                <CheckBox x:Name="AutoScrollCheck" Content="自动滚动" IsChecked="True"
                          VerticalAlignment="Center" Margin="0,0,16,0"
                          Foreground="{DynamicResource PrimaryText}"
                          FontSize="14"/>
                <!-- 日志类型筛选 -->
                <ComboBox x:Name="FilterCombo" 
                          Width="120" 
                          Margin="0,0,12,0"
                          VerticalContentAlignment="Center"
                          SelectedValuePath="Tag"
                          DisplayMemberPath="Content"
                          SelectedValue="{Binding FilterType, Mode=TwoWay}">
                    <ComboBoxItem Content="全部" Tag="0" IsSelected="True"/>
                    <ComboBoxItem Content="📦 已备份" Tag="1"/>
                    <ComboBoxItem Content="🔄 重命名" Tag="2"/>
                    <ComboBoxItem Content="📝 新文件" Tag="3"/>
                    <ComboBoxItem Content="📦 备份完成" Tag="4"/>
                    <ComboBoxItem Content="🔍 检测" Tag="5"/>
                    <ComboBoxItem Content="❌ 错误" Tag="6"/>
                    <ComboBoxItem Content="⚠️ 警告" Tag="7"/>
                    <ComboBoxItem Content="⏹️ 停止" Tag="8"/>
                    <ComboBoxItem Content="🧹 清理" Tag="9"/>
                </ComboBox>

                <!-- 当前筛选提示 -->
                <TextBlock Text="{Binding FilterType, Converter={x:Static local:LogFilterConverter.Instance}}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource SubtleText}"/>
                <!-- 清空按钮 -->
                <Button x:Name="ClearButton" Content="🗑️ 清空" Width="90" Margin="0,0,12,0"
                        Command="{Binding ClearLogsCommand}"
                        Style="{DynamicResource AccentButton}"
                        ToolTip="清空当前显示的日志"
                        FontSize="12"
                        Padding="20,8"/>
                <!-- 关闭按钮 -->
                <Button x:Name="CloseButton" Content="✖ 关闭" Width="90" Margin="0,0,0,0"
                        Click="CloseButton_Click"
                        Style="{DynamicResource AccentButton}"
                        ToolTip="关闭日志窗口"
                        FontSize="12"
                        Padding="20,8"/>
                <!-- 日志计数 -->
                <TextBlock x:Name="CountText" Text="{Binding CountText}" 
                           VerticalAlignment="Center" Margin="24,0,0,0"
                           FontSize="15"
                           Foreground="#555555"
                           FontWeight="Bold"/>
            </DockPanel>
        </Border>

        <!-- 日志列表 -->
        <ListView Grid.Row="1" x:Name="LogList" 
                  ItemsSource="{Binding FilteredLogs}"
                  Background="{DynamicResource CardBrush}"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  FontSize="14"
                  Padding="0,2">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        SnapsToDevicePixels="true">
                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" 
                                                Value="{DynamicResource AccentBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10" Margin="0,4" CornerRadius="6"
                            Background="{Binding ColorBrush}"
                            Opacity="0.96">
                        <DockPanel>
                            <!-- 时间戳（加粗、深色、更宽） -->
                            <TextBlock DockPanel.Dock="Left" Text="{Binding TimeStamp}"
                                       FontFamily="Consolas" FontSize="14"
                                       Foreground="#333333"
                                       FontWeight="Bold"
                                       Margin="0,2,14,0"
                                       Width="85"
                                       VerticalAlignment="Top"/>
                            <!-- 消息内容（自动换行，黑色文字） -->
                            <TextBlock Text="{Binding Message}" 
                                       FontFamily="Consolas" FontSize="14"
                                       Foreground="#222222"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="22"/>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}" 
                Padding="12,8" CornerRadius="6" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="💡 提示：此窗口显示实时日志（仅在打开时收集），关闭后日志继续写入文件。双击清空按钮可快速清空。"
                           FontSize="12" Foreground="{DynamicResource SubtleText}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="LastUpdateText" Text=""
                           HorizontalAlignment="Right"
                           FontSize="12" Foreground="{DynamicResource SubtleText}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
