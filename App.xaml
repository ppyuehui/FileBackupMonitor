<Application x:Class="FileBackupMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FileBackupMonitor.Converters"
             StartupUri="Views/MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 控件样式（主题无关） -->
                <ResourceDictionary Source="Themes/ThemeStyles.xaml"/>
                <!-- 默认深色主题，启动时由 App.xaml.cs 根据设置覆盖 -->
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:CategoryToBrushConverter x:Key="CategoryToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
