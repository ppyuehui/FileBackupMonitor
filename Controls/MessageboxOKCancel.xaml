<Window 
    x:Class="MyMessagebox.Controls.MessageboxOKCancel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:MyMessagebox.Controls"
    mc:Ignorable="d" 
    Title="MessageBox" 
    Height="150" 
    Width="300" 
    WindowStartupLocation="CenterScreen" 
    ResizeMode="NoResize" 
    ShowInTaskbar="False" 
    WindowStyle="ToolWindow"
    Topmost="True" Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    <DockPanel >
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Center" >
            <!--<Button Content="确定"  Click="OK_Click" IsDefault="True"/>
            <Button Content="取消" Click="Cancle_Click"/>-->
            <Button x:Name="btnOK"
                    Content="确定" 
                    Click="OK_Click"
                    IsDefault="True" Width="80" Margin="5"  Style="{DynamicResource SecondaryButton}"/>
            <Button x:Name="btnCancel"
                    Content="取消" 
                    Click="Cancel_Click"
                    IsCancel="True" Width="80" Margin="5" Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="messageText" 
                       Text="消息内容" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="14"/>
            <!--<TextBlock Name="message" Text="111" FontSize="14"  HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>-->
        </ScrollViewer>

    </DockPanel>
    <!--<Grid Margin="10">
        <Grid.RowDefinitions>
